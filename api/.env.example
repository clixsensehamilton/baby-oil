# ============================================
# Oil Intelligence Index - API Configuration
# ============================================
# Copy this file to .env and fill in your values.

# --- Database (Neon DB) ---
# Get your connection string from https://neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# --- CORS ---
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=["http://localhost:3000"]

# --- Scraper ---
SCRAPE_INTERVAL_MINUTES=15

# --- NASA FIRMS (Satellite Thermal Anomalies) ---
# Get your free MAP_KEY at: https://firms.modaps.eosdis.nasa.gov/api/area/
NASA_FIRMS_MAP_KEY=your-nasa-firms-map-key-here

# --- ACLED (Armed Conflict Data) ---
# Register free at: https://acleddata.com/
ACLED_EMAIL=your-email@example.com
ACLED_PASSWORD=your-acled-password

# --- EIA (US Energy Information Administration) ---
# Register free at: https://www.eia.gov/opendata/register.php
EIA_API_KEY=your-eia-key-here
